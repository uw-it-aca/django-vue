{
  "language_servers": ["oxlint", "..."],
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 79,
          "lint": {
            "select": ["E", "W"],
            "ignore": ["F"]
          },
          "organizeImports": true
        }
      }
    }
  },
  "languages": {
    "CSS": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "format_on_save": "off"
    },
    "SCSS": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "format_on_save": "off"
    },
    "Vue.js": {
      "language_servers": ["vue-language-server", "oxlint", "..."],
      "formatter": { "language_server": { "name": "oxfmt" } },
      "format_on_save": "off"
    },
    "JavaScript": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "format_on_save": "off"
    },
    "JSON": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "format_on_save": "off"
    },
    "JSONC": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "format_on_save": "off"
    },
    "Python": {
      "formatter": { "language_server": { "name": "ruff" } },
      "format_on_save": "off"
    },
    "TypeScript": {
      "formatter": { "language_server": { "name": "oxfmt" } },
      "format_on_save": "off"
    }
  }
}
